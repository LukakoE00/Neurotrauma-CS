<?xml version="1.0" encoding="utf-8" ?>
<Override>
  <Afflictions>
    <!-- Bone Damage. Visible on Health Scanner. Causes: Bone Death if severe enough. -->
    <Affliction
      name=""
      description=""
      identifier="bonedamage"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"

      showinhealthscannerthreshold="20"
      showiconthreshold="999"
      maxstrength="100">

      <icon texture="Content/UI/MainIconsAtlas.png" sourcerect="128,384,128,128" color="195,136,60,255" origin="0,0"/>
    </Affliction>

    <!-- Stimulated Bone Growth. Visible in Health UI. Cures: Bone Death and Bone Damage. -->
    <Affliction
      name=""
      description=""
      identifier="stimulatedbonegrowth"
      
      healableinmedicalclinic="false"
      isbuff="true"
      targets="human"
      limbspecific="true"
      type="resistance"
      
      showinhealthscannerthreshold="999"
      showiconthreshold="0"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="2,4" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Fractured Extremity. Visible in Health UI and Scanner. -->
    <Affliction
      name=""
      description=""
      identifier="fracturedextremity"

      healableinmedicalclinic="true"
      basehealcost="130"
      targets="human"
      limbspecific="true"
      type="fractures"

      showinhealthscannerthreshold="5"
      showiconthreshold="90"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="6,2" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Fractured Ribs -->
    <Affliction
      name=""
      description=""
      identifier="fracturedribs"
      
      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"
      type="fractures"

      showinhealthscannerthreshold="5"
      showiconthreshold="90"
      maxstrength="100">

      <Effect minstrength="0" maxstrength="6">
        <StatusEffect target="Character">
          <sound file="%ModDir%/Sounds/Bones/bonebreak4.ogg"  selectionmode="random"/>
          <sound file="%ModDir%/Sounds/Bones/bonebreak3.ogg"/>
          <sound file="%ModDir%/Sounds/Bones/bonebreak2.ogg"/>
          <sound file="%ModDir%/Sounds/Bones/bonebreak1.ogg"/>
        </StatusEffect>
      </Effect>

      <Effect minstrength="6" maxstrength="100"/>

      <!-- Cause Pneumothorax when unbandaged every 60 to 120 seconds when not Bandaged. -->
      <PeriodicEffect mininterval="60" maxinterval="120">
        <StatusEffect target="Character" multiplyafflictionsbymaxvitality="true" comparison="And">
          <Conditional bandaged="eq 0" bandageddirty="eq 0" />
          <Conditional pneumothorax="eq 0"/>
          <Affliction identifier="pneumothorax" amount="5" probability="0.3" />
        </StatusEffect>
      </PeriodicEffect>

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="6,2" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Fractured Neck -->
    <Affliction
      name=""
      description=""
      identifier="fracturedneck"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Head"
      type="fractures"

      showinhealthscannerthreshold="5"
      showiconthreshold="90"
      maxstrength="100">

      <Effect minstrength="0" maxstrength="6">
        <StatusEffect target="Character">
          <sound file="%ModDir%/Sounds/Bones/bonebreak4.ogg"  selectionmode="random"/>
          <sound file="%ModDir%/Sounds/Bones/bonebreak3.ogg"/>
          <sound file="%ModDir%/Sounds/Bones/bonebreak2.ogg"/>
          <sound file="%ModDir%/Sounds/Bones/bonebreak1.ogg"/>
        </StatusEffect>
      </Effect>

      <Effect minstrength="6" maxstrength="100"/>

      <!-- Cause Internal Damage to the Head if not Bandaged. -->
      <PeriodicEffect mininterval="1" maxinterval="1">
        <StatusEffect target="Character" multiplyafflictionsbymaxvitality="true" targetlimb="Head" disabledeltatime="true">
          <Conditional bandaged="eq 0" bandageddirty="eq 0" />
          <Affliction identifier="internaldamage" indicatorlimb="Limb" amount="0.1"/>
        </StatusEffect>
      </PeriodicEffect>

      <!-- Cause Spinal Cord Injury when unbandaged every 20 to 50 seconds. -->
      <PeriodicEffect mininterval="20" maxinterval="50">
        <StatusEffect target="Character" targetlimbs="Head" multiplyafflictionsbymaxvitality="true" comparison="And">
          <Conditional bandaged="eq 0" bandageddirty="eq 0" />
          <Conditional fracturedneck="gte 100"/>
          <Affliction identifier="spinalcordinjury" amount="5" />
        </StatusEffect>
      </PeriodicEffect>

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="1,3" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Fractured Skull -->
    <Affliction
      name=""
      description=""
      identifier="fracturedskull"
      
      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Head"
      type="fractures"

      showinhealthscannerthreshold="5"
      showiconthreshold="90"
      maxstrength="100">

      <Effect minstrength="0" maxstrength="6">
        <StatusEffect target="Character">
          <sound file="%ModDir%/Sounds/Bones/bonebreak4.ogg"  selectionmode="random"/>
          <sound file="%ModDir%/Sounds/Bones/bonebreak3.ogg"/>
          <sound file="%ModDir%/Sounds/Bones/bonebreak2.ogg"/>
          <sound file="%ModDir%/Sounds/Bones/bonebreak1.ogg"/>
        </StatusEffect>
      </Effect>

      <Effect minstrength="6" maxstrength="100"/>

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="2,3" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Dislocation -->
    <Affliction
      name=""
      description=""
      identifier="dislocation"

      healableinmedicalclinic="true"
      basehealcost="80"
      targets="human"
      limbspecific="true"
      type="fractures"

      showinhealthscannerthreshold="5"
      showiconthreshold="30"
      maxstrength="100">

      <Effect minstrength="0" maxstrength="6" strengthchange="10">
        <StatusEffect target="Character" multiplyafflictionsbymaxvitality="true">
          <sound file="%ModDir%/Sounds/Bones/bonebreak4.ogg"  selectionmode="random"/>
          <sound file="%ModDir%/Sounds/Bones/bonebreak3.ogg"/>
          <sound file="%ModDir%/Sounds/Bones/bonebreak2.ogg"/>
          <sound file="%ModDir%/Sounds/Bones/bonebreak1.ogg"/>
          <Affliction identifier="severepain" amount="1" />
        </StatusEffect>
      </Effect>
      <Effect minstrength="6" maxstrength="100" strengthchange="1.5"/>

      <PeriodicEffect mininterval="1" maxinterval="1">
        <StatusEffect target="Character" disabledeltatime="true" stackable="false" delay="1" checkconditionalalways="false">
          <Conditional ishuman="false" />
          <ReduceAffliction identifier="dislocation" amount="1000"/>  <!--- This used to be dislocation1, I uh, changed it to dislocation -->
        </StatusEffect>
      </PeriodicEffect>

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="0,3" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>
  </Afflictions>
</Override>