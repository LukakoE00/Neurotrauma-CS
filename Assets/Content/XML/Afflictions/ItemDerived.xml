<?xml version="1.0" encoding="utf-8" ?>
<Override>
  <Afflictions>
     <!-- Adrenaline / Epinephrine. Visible on Hematology Analyzer. Counters Pain and increases Blood Pressure. -->
    <Affliction
      name=""
      description=""
      identifier="afadrenaline"
      
      healableinmedicalclinic="false"
      targets="human"
      type="resistance"
      isbuff="true"
      limbspecific="false"
      
      showinhealthscannerthreshold="999"
      showiconthreshold="999"
      maxstrength="100">

      <Effect minstrength="0" maxstrength="100" strengthchange="0">
        <StatusEffect target="Character">
          <StatValue stattype="MeleeAttackMultiplier" minvalue="0.2" maxvalue="0.2" />
        </StatusEffect>

        <StatusEffect target="Character" multiplyafflictionsbymaxvitality="true" comparison="and">
          <Conditional analgesia="lte 4.5" />
          <Conditional ishuman="true" />
          <Affliction identifier="analgesia" amount="1" />
        </StatusEffect>
      </Effect>

      <icon texture="Content/UI/MainIconsAtlas.png" sourcerect="256,896,128,128" color="10,193,114,255" origin="0,0"/>
    </Affliction>

    <!-- Needle in the Torso. Visible in Health UI. First-Aid for Pneumothorax. -->
