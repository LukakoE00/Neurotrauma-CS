    <Affliction
      name=""
      description=""
      identifier="bandaged"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="true"
      type="bandage"
      isbuff="true"

      showinhealthscannerthreshold="999"
      showiconthreshold="0"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="0,4" sheetelementsize="128,128" origin="0,0"/>
