    <!-- Plaster Cast. Visible in Health UI. Counters negative effects and heals Fractures on extremities. -->
    <Affliction
      name=""
      description=""
      identifier="plastercast"
      
      healableinmedicalclinic="false"
      targets="human"
      limbspecific="true"
      type="resistance"
      isbuff="true"

      showinhealthscannerthreshold="999"
      showiconthreshold="0"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="2,4" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Arterial Bleeding -->
    <Affliction
      name=""
      description=""
      identifier="arterialcut"

      healableinmedicalclinic="true"
      basehealcost="210"
      targets="human"
      type="arterialcut"
      limbspecific="true"

      showinhealthscannerthreshold="0"
      showiconthreshold="0"
      maxstrength="100">

       <Effect minstrength="0" maxstrength="100" strengthchange="1" >
        <StatusEffect target="Character" comparison="and">
          <Conditional tourniqueted="lte 1"/>
          <Conditional bloodloss="lte 99.5"/>
          <Affliction identifier="bloodloss" strength="1.5" />
        </StatusEffect>

        <StatusEffect target="Limb" comparison="and">
          <Conditional tourniqueted="lte 1"/>
          <Conditional bloodloss="lte 99.5"/>
          <ParticleEmitter particle="bloodsplash" particlespersecond="50" scalemin="0.5" scalemax="0.45" velocitymin="0" velocitymax="40" anglemin="0" anglemax="360" />
          <ParticleEmitter particle="waterblood" particlespersecond="20" scalemin="0.5" scalemax="0.45" velocitymin="0" velocitymax="40" anglemin="0" anglemax="360" />
        </StatusEffect>
        
        <StatusEffect target="Character" conditional="or">
          <Conditional ishuman="False" />
          <ReduceAffliction identifier="arterialcut" amount="999"/>
        </StatusEffect>
      </Effect>

      <PeriodicEffect mininterval="6" maxinterval="6">
        <StatusEffect target="Character" comparison="and">
          <Conditional tourniqueted="eq 0" inwater="false"/>
          <Explosion range="0.0" structuredamage="0" itemdamage="0" force="0.0" severlimbsprobability="0.0" decal="blood" decalsize="0.85" shockwave="false" underwaterbubble="false" />
        </StatusEffect>
      </PeriodicEffect>

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="3,3" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Gangrene / Cell death caused by cut off bloodflow. Visible in Health UI and Scanner. Causes: Sepsis. Requires Amputation above 15%. -->
    <Affliction
      name=""
      description=""
      identifier="gangrene"
      
      healableinmedicalclinic="false"
      targets="human"
      limbspecific="True"
      iconcolors="200,0,0,255;200,0,0,255;200,0,0,255"

      showinhealthscannerthreshold="0"
      showiconthreshold="15"
      maxstrength="100">

      <Effect minstrength="15" maxstrength="50" minvitalitydecrease="0" maxvitalitydecrease="15"/>
      
      <Effect minstrength="50" maxstrength="100" minvitalitydecrease="15" maxvitalitydecrease="25"/>

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="6,3" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>
