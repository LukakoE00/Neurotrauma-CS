          <StatusEffect target="limb" checkconditionalalways="false" disabledeltatime="false" duration="1" stackable="false">
            <Conditional onfire="gt 1" />
            <Affliction identifier="burn" amount="5" />
          </StatusEffect>
          
          <StatusEffect target="limb" disabledeltatime="true" stackable="true" duration="1" checkconditionalalways="false">
            <Conditional onfire="gt 1" />
            <ParticleEmitter particle="flamethrower" particlespersecond="20" anglemin="60" anglemax="120" velocitymin="10" velocitymax="100" scalemin="0.1" scalemax="0.3" highqualitycollisiondetection="true"/>
            <ParticleEmitter particle="flamethrowersmoke" particlespersecond="10" anglemin="60" anglemax="120" velocitymin="500" velocitymax="1000"/>
          </StatusEffect>
      </PeriodicEffect>

      <icon texture="Content/UI/MainIconsAtlas.png" sourcerect="768,640,128,128" color="195,104,60,255" origin="0,0"/>
    </Affliction>

