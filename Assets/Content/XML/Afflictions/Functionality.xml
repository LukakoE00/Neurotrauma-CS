      showinhealthscannerthreshold="999"
      showiconthreshold="1"
      maxstrength="2">

        <PeriodicEffect mininterval="1" maxinterval="1">
          <StatusEffect target="Limb" disabledeltatime="true" stackable="false" delay="0.1" checkconditionalalways="false">
            <ReduceAffliction identifier="onfire" amount="0.2"/>
          </StatusEffect>

          <StatusEffect target="Character" disabledeltatime="true" stackable="false" delay="0.1" checkconditionalalways="false">
            <Conditional inwater="true"/>
            <ReduceAffliction identifier="onfire" amount="1000" />
          </StatusEffect>

          <StatusEffect target="Character" disabledeltatime="true" stackable="false" delay="0.1" checkconditionalalways="false" comparison="and">
            <Conditional pressureProtection="gte 1000"/>
            <Conditional ishuman="true"/>
            <ReduceAffliction identifier="onfire" amount="1000" />
          </StatusEffect>

          <StatusEffect target="limb" disabledeltatime="true" stackable="false" delay="0.1" checkconditionalalways="false" comparison="and">
            <Conditional IsRagdolled="true"/>
            <Conditional ishuman="true"/>
            <ReduceAffliction identifier="onfire" amount="-0.2" />
          </StatusEffect>

          <StatusEffect target="limb,character" multiplyafflictionsbymaxvitality="true" disabledeltatime="true" stackable="false" delay="0.1" checkconditionalalways="false">
