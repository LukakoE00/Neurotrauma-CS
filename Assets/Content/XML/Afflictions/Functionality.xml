      name=""
      description=""
      identifier="luabotomy"
      
      healableinmedicalclinic="false"
      limbspecific="false"
      indicatorlimb="Head"
      targets="human"
      iconcolors="255,255,255,255;255,255,255,255"
      
      showinhealthscannerthreshold="999"
      showiconthreshold="14"
