<?xml version="1.0" encoding="utf-8" ?>
<Override>
  <Afflictions>
    <!-- Blood Pressure. Visible on Health Scanner and Hematology Analyzer. -->
    <Affliction
      name=""
      description=""
      identifier="bloodpressure"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"
      isbuff="true"

      showinhealthscannerthreshold="0"
      showiconthreshold="999"
      maxstrength="200">

      <Effect minstrength="0" maxstrength="5" strengthchange="10" />
      <Effect minstrength="5" maxstrength="200" strengthchange="0" />

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sourcerect="128,128,128,128" color="68,157,198,255" origin="0,0"/>
    </Affliction>

    <!-- Hypoxemia / Low oxygen presence in blood. Visible on Health Scanner. -->
    <Affliction
      name=""
      description=""
      identifier="hypoxemia"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"

      showinhealthscannerthreshold="5"
      showiconthreshold="999"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sourcerect="128,128,128,128" color="68,157,198,255" origin="0,0"/>
    </Affliction>

    <!-- Alkalosis. Visible on Hematology Analyzer. -->
    <Affliction
      name=""
      description=""
      identifier="alkalosis"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"

      showinhealthscannerthreshold="999"
      showiconthreshold="999"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sourcerect="0,128,128,128" color="0,255,0,255" origin="0,0"/>
    </Affliction>

    <!-- Acidosis. Visible on Hematology Analyzer. -->
    <Affliction
      name=""
      description=""
      identifier="acidosis"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"

      showinhealthscannerthreshold="999"
      showiconthreshold="999"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sourcerect="0,128,128,128" color="0,255,0,255" origin="0,0"/>
    </Affliction>

    <!-- Hemotransfusion Shock a.k.a. wrong blood type, idiot! -->
    <Affliction
      name=""
      description=""
      identifier="hemotransfusionshock"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"
      
      showinhealthscannerthreshold="10"
      showiconthreshold="999"
      maxstrength="100">

      <Effect minstrength="0" maxstrength="100" strengthchange="-0.5"/>

      <PeriodicEffect mininterval="1" maxinterval="3">
        <StatusEffect target="character" multiplyafflictionsbymaxvitality="true" disabledeltatime="true" comparison="and" checkconditionalalways="false">
          <Conditional hemotransfusionshock="lt 70"/>
          <Conditional hemotransfusionshock="gte 15"/>
          <Affliction identifier="bloodloss" amount="1"/>
          <Affliction identifier="organdamage" amount="0.25"/>
          <Affliction identifier="liverdamage" amount="0.25"/>
          <Affliction identifier="kidneydamage" amount="0.25"/>
          <Affliction identifier="heartdamage" amount="0.25"/>
          <Affliction identifier="lungdamage" amount="0.25"/>
        </StatusEffect>
        
        <StatusEffect target="character" multiplyafflictionsbymaxvitality="true" disabledeltatime="true" comparison="and" checkconditionalalways="false">
          <Conditional hemotransfusionshock="lt 15"/>
          <Affliction identifier="bloodloss" amount="1"/>
          <Affliction identifier="organdamage" amount="0.5"/>
          <Affliction identifier="liverdamage" amount="0.5"/>
          <Affliction identifier="kidneydamage" amount="0.5"/>
          <Affliction identifier="heartdamage" amount="0.5"/>
          <Affliction identifier="lungdamage" amount="0.5"/>
        </StatusEffect>
      </PeriodicEffect>

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sourcerect="256,0,128,128" color="68,157,198,255" origin="0,0"/>
    </Affliction>

    <!-- Sepsis / Bacteria in the blood. Visible on Hematology Analyzer. Causes: systemic infection, life-threatening complications, Gangrene. -->
    <Affliction
      name=""
      description=""
      identifier="sepsis"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Torso"

      showinhealthscannerthreshold="999"
      showiconthreshold="999"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sourcerect="768,0,128,128" color="139,60,42,255" origin="0,0"/>
    </Affliction>

    <!-- Immunity. Visible on the Hematology Analyzer. Heals you passively if high enough -->
    <Affliction
      name=""
      description=""
      identifier="immunity"
      
      healableinmedicalclinic="false"
      targets="human"
      isbuff="true"
      limbspecific="false"
      indicatorlimb="Torso"

      showinhealthscannerthreshold="999"
      showiconthreshold="999"
      maxstrength="100">

      <icon texture="Content/UI/MainIconsAtlas.png" sourcerect="256,896,128,128" color="10,193,114,255" origin="0,0"/>
    </Affliction>
  </Afflictions>
</Override>