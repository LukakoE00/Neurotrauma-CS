<?xml version="1.0" encoding="utf-8" ?>
<Override>
  <Afflictions>
    <!-- Stroke. Visible on Health Scanner. Causes: Coma, Cerebral Hypoxia (Neurotrauma), Numbness, Seizures. -->
    <Affliction
      name=""
      description=""
      identifier="stroke"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Head"

      showinhealthscannerthreshold="0"
      showiconthreshold="999"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sourcerect="0,128,128,128" color="0,255,0,255" origin="0,0"/>
    </Affliction>

    <!-- Neurotrauma / Low oxygen presence in the brain. Visible on Health Scanner. Lethal. -->
    <Affliction
      name=""
      description=""
      identifier="neurotrauma"
      
      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Head"

      showinhealthscannerthreshold="10"
      showiconthreshold="999"
      maxstrength="200">

      <Effect minstrength="0" maxstrength="180"
        minscreendistort="0"
        maxscreendistort="1"
        minscreenblur="0"
        maxscreenblur="1"
        minradialdistort="0"
        maxradialdistort="1"
        MultiplyByMaxVitality="true"
        minvitalitydecrease="0"
        maxvitalitydecrease="0.9">
      </Effect>

      <Effect minstrength="180" maxstrength="200"
        minscreendistort="1"
        maxscreendistort="1"
        minscreenblur="1"
        maxscreenblur="1"
        minradialdistort="1"
        maxradialdistort="1"
        MultiplyByMaxVitality="true"
        minvitalitydecrease="0.9"
        maxvitalitydecrease="2">
      </Effect>

      <icon texture="Content/UI/MainIconsAtlas.png" sourcerect="128,640,128,128" color="195,177,60,255" origin="0,0"/>
    </Affliction>

    <!-- Seizure. Visible in Health UI and Scanner. -->
    <Affliction
      name=""
      description=""
      identifier="seizure"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Head"

      showinhealthscannerthreshold="0"
      showiconthreshold="0"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="1,0" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Coma. Visible on Scanner. -->
    <Affliction
      name=""
      description=""
      identifier="coma"
      
      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Head"
    
      showinhealthscannerthreshold="10"
      showiconthreshold="999"
      maxstrength="100">

      <icon texture="Content/UI/MainIconsAtlas.png" sourcerect="128,640,128,128" color="195,177,60,255" origin="0,0"/>
    </Affliction>

    <!-- Brain removed. Visible in Health UI and Scanner. Causes: Rapid Cerebral Hypoxia / Neurotrauma and death. -->
    <Affliction
      name=""
      description=""
      identifier="brainremoved"
      
      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Head"
      iconcolors="84,211,211,255;84,211,211,255"

      showinhealthscannerthreshold="50"
      showiconthreshold="50"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons.png" sheetindex="4,5" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>

    <!-- Brain Replacement. Visible in Health UI and Scanner. Used for Organ Transplant Surgery. -->
    <Affliction
      name=""
      description=""
      identifier="brainswap"

      healableinmedicalclinic="false"
      targets="human"
      limbspecific="false"
      indicatorlimb="Head"
      iconcolors="84,211,211,255;84,211,211,255"

      showinhealthscannerthreshold="0"
      showiconthreshold="50"
      maxstrength="100">

      <icon texture="%ModDir%/Images/AfflictionIcons2.png" sheetindex="4,5" sheetelementsize="128,128" origin="0,0"/>
    </Affliction>
  </Afflictions>
</Override>